---
import { GithubLogo, LinkedinLogo } from '@phosphor-icons/react/dist/ssr';
import { siteConfig } from '../config';
import Terminal from './Terminal.astro';

const { hero } = siteConfig;
---

<section class="hero" id="hero">
  <div class="hero-grid-bg" aria-hidden="true"></div>

  <div class="container hero-grid">
    <div class="hero-status" style="--i:0">
      {hero.status}
    </div>

    <h1 class="hero-title" style="--i:1">
      {hero.title}
    </h1>

    <p class="hero-intro" style="--i:2">
      {hero.intro}
    </p>

    <div class="terminal-wrapper" style="--i:3">
      <Terminal
        meta={hero.terminal.meta}
        prompt={hero.terminal.prompt}
        command={hero.terminal.command}
        output={hero.terminal.output}
      />
    </div>

    <div class="hero-actions" style="--i:4">
      <a class="hero-cta" href={hero.cta.href} download>
        {hero.cta.label}
      </a>

      <a
        class="hero-icon"
        href={hero.socials.github}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
      >
        <GithubLogo weight="duotone" />
      </a>

      <a
        class="hero-icon"
        href={hero.socials.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
      >
        <LinkedinLogo weight="duotone" />
      </a>
    </div>
  </div>

  <style>
    .hero {
      position: relative;
      padding-top: 6rem;
      padding-bottom: 3rem;
      overflow: hidden;
    }

    /* Minimal grid background */
    .hero-grid-bg {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      pointer-events: none;
      z-index: 0;
      background-image: 
        linear-gradient(var(--border) 1px, transparent 1px),
        linear-gradient(90deg, var(--border) 1px, transparent 1px);
      background-size: 40px 40px;
      opacity: 0.15;
      mask-image: radial-gradient(circle at 50% 30%, black 30%, transparent 80%);
      -webkit-mask-image: radial-gradient(circle at 50% 30%, black 30%, transparent 80%);
    }

    .hero-grid {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 1.75rem;
    }

    .hero-grid > * {
      opacity: 0;
      animation: fade-in-up 0.4s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    }

    .hero-grid > *:nth-child(1) { animation-delay: 0ms; }
    .hero-grid > *:nth-child(2) { animation-delay: 40ms; }
    .hero-grid > *:nth-child(3) { animation-delay: 80ms; }
    .hero-grid > *:nth-child(4) { animation-delay: 120ms; }
    .hero-grid > *:nth-child(5) { animation-delay: 160ms; }

    .hero-status {
      font-family: 'JetBrains Mono', monospace;
      color: var(--accent);
      font-size: 0.9rem;
      letter-spacing: 0.02em;
    }

    .hero-title {
      max-width: 100%;
      white-space: nowrap;
      letter-spacing: -0.02em;
    }

    .hero-intro {
      max-width: 52ch;
      font-size: 1.1rem;
      color: var(--text-muted);
      line-height: 1.7;
      text-wrap: pretty;
    }

    .terminal-wrapper {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .terminal-wrapper:hover {
      transform: translateY(-2px);
    }

    .hero-actions {
      display: flex;
      gap: 0.85rem;
      align-items: center;
      flex-wrap: wrap;
      margin-top: 0.5rem;
    }

    .hero-cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.7rem 1.6rem;
      border: 1px solid var(--accent);
      background: var(--accent);
      color: var(--bg);
      border-radius: 2px;
      font-weight: 500;
      font-size: 0.9rem;
      text-decoration: none;
      transition: all 200ms ease;
    }

    .hero-cta:hover {
      background: transparent;
      color: var(--accent);
      transform: translateY(-1px);
    }

    .hero-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2.6rem;
      height: 2.6rem;
      border: 1px solid var(--border);
      border-radius: 2px;
      color: var(--text-muted);
      transition: all 200ms ease;
    }

    .hero-icon:hover {
      color: var(--accent);
      border-color: var(--accent);
      transform: translateY(-1px);
    }

    @media (max-width: 699px) {
      .hero {
        padding-top: 4rem;
        padding-bottom: 2rem;
      }

      .hero-grid > * {
        animation-delay: 0ms !important;
      }

      .hero-title {
        white-space: normal;
        max-width: 100%;
      }

      .hero-intro {
        font-size: 1rem;
        max-width: 100%;
      }

      .hero-grid-bg {
        background-size: 30px 30px;
        opacity: 0.1;
        mask-image: radial-gradient(circle at 50% 20%, black 20%, transparent 70%);
        -webkit-mask-image: radial-gradient(circle at 50% 20%, black 20%, transparent 70%);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .terminal-wrapper:hover,
      .hero-cta:hover,
      .hero-icon:hover {
        transform: none;
      }
    }
  </style>
</section>