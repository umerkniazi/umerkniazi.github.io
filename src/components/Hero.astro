---
import { siteConfig } from '../config';

const { hero, name } = siteConfig;
---

<section class="section hero-section" id="hero">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-copy">
        {hero.eyebrow && <p class="section-kicker hero-kicker">{hero.eyebrow}</p>}
        <h1 class="hero-title">{name}</h1>
        <p class="hero-intro">{hero.tagline}</p>

        <div class="hero-actions">
          {hero.cta && (
            <a href={hero.cta.href} class="button button-primary hero-button">{hero.cta.label}</a>
          )}
          <a href="/#projects" class="button-ghost">View projects</a>
        </div>
      </div>

      <aside class="hero-panel card" aria-label="Profile summary">
        <div class="hero-panel-row">
          <span class="panel-label">Status</span>
          <p>{hero.status.label}</p>
        </div>
        <div class="hero-panel-row">
          <span class="panel-label">Focus</span>
          <p>Systems, applied ML, terminal tools, and small games.</p>
        </div>
        <div class="hero-panel-row">
          <span class="panel-label">Approach</span>
          <p>Build the thing, inspect the failure modes, then tighten the design.</p>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .hero-section {
    padding-top: var(--space-20);
    padding-bottom: var(--space-12);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(300px, 0.75fr);
    gap: var(--space-8);
    align-items: start;
  }

  .hero-copy {
    display: grid;
    gap: var(--space-6);
    padding-bottom: var(--space-4);
  }

  .hero-kicker {
    margin-bottom: 0;
  }

  .hero-title {
    max-width: 9ch;
  }

  .hero-intro {
    color: var(--text-muted);
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    max-width: 55ch;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: center;
  }

  .hero-button {
    min-width: 10.5rem;
  }

  .hero-panel {
    display: grid;
    gap: var(--space-4);
    padding: var(--space-6);
  }

  .hero-panel-row {
    display: grid;
    gap: var(--space-2);
    padding-bottom: var(--space-4);
    border-bottom: var(--border-width-thin) solid var(--border);
  }

  .hero-panel-row:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .panel-label {
    color: var(--text-subtle);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-panel-row p {
    color: var(--text);
    line-height: var(--leading-normal);
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-title {
      max-width: none;
    }
  }

  @media (max-width: 720px) {
    .hero-section {
      padding-top: var(--space-16);
    }

    .hero-panel {
      padding: var(--space-5);
    }
  }
</style>