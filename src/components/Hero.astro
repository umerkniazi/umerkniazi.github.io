---
import { GithubLogo, LinkedinLogo } from '@phosphor-icons/react/dist/ssr';
import { siteConfig } from '../config';
import Terminal from './Terminal.astro';

const { hero } = siteConfig;
---

<section class="hero" id="hero">
  <div class="hero-glow" aria-hidden="true"></div>

  <div class="container hero-grid">
    <div class="hero-status" style="--i:0">
      {hero.status}
    </div>

    <h1 style="--i:1">
      {hero.title}
    </h1>

    <p class="hero-intro" style="--i:2">
      {hero.intro}
    </p>

    <div style="--i:3">
      <Terminal
        meta={hero.terminal.meta}
        prompt={hero.terminal.prompt}
        command={hero.terminal.command}
        output={hero.terminal.output}
      />
    </div>

    <div class="hero-actions" style="--i:4">
      <a class="hero-cta" href={hero.cta.href} download>
        {hero.cta.label}
      </a>

      <a
        class="hero-icon"
        href={hero.socials.github}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
      >
        <GithubLogo weight="duotone" />
      </a>

      <a
        class="hero-icon"
        href={hero.socials.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
      >
        <LinkedinLogo weight="duotone" />
      </a>
    </div>
  </div>

  <style>
    .hero {
      position: relative;
      padding-top: 6rem;
      padding-bottom: 2rem;
    }

    .hero-grid {
      display: grid;
      gap: 1.5rem;
    }

    .hero-grid > * {
      opacity: 0;
      animation: fade-in-up 0.4s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    }

    .hero-grid > *:nth-child(1) { animation-delay: 0ms; }
    .hero-grid > *:nth-child(2) { animation-delay: 40ms; }
    .hero-grid > *:nth-child(3) { animation-delay: 80ms; }
    .hero-grid > *:nth-child(4) { animation-delay: 120ms; }
    .hero-grid > *:nth-child(5) { animation-delay: 160ms; }

    .hero-status {
      font-family: 'JetBrains Mono', monospace;
      color: var(--accent);
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .hero-intro {
      max-width: 55ch;
      font-size: 1.08rem;
      color: var(--text-muted);
      line-height: 1.75;
    }

    .hero-actions {
      display: flex;
      gap: 0.75rem;
      align-items: center;
      flex-wrap: wrap;
    }

    .hero-cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.6rem 1.4rem;
      border: 1px solid var(--accent);
      background: var(--accent);
      color: var(--bg);
      border-radius: 2px;
      text-decoration: none;
      transition: all 150ms ease;
    }

    .hero-cta:hover {
      background: transparent;
      color: var(--accent);
    }

    .hero-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2.5rem;
      height: 2.5rem;
      border: 1px solid var(--border);
      border-radius: 2px;
      color: var(--text-muted);
      transition: all 150ms ease;
    }

    .hero-icon:hover {
      color: var(--text);
      border-color: var(--text-muted);
    }

    @media (max-width: 699px) {
      .hero {
        padding-top: 4rem;
      }

      .hero-grid > * {
        animation-delay: 0ms !important;
      }
    }
  </style>
</section>