---
import { GithubLogo, LinkedinLogo } from '@phosphor-icons/react/dist/ssr';
import { siteConfig } from '../config';
import Terminal from './Terminal.astro';

const { hero } = siteConfig;
---

<section class="hero" id="hero">
  <div class="hero-grid-bg" aria-hidden="true"></div>

  <div class="container hero-grid">
    <div class="hero-status">
      {hero.status}
    </div>

    <h1 class="hero-title">
      {hero.title}
    </h1>

    <p class="hero-intro">
      {hero.intro}
    </p>

    <div class="terminal-wrapper">
      <Terminal
        meta={hero.terminal.meta}
        prompt={hero.terminal.prompt}
        command={hero.terminal.command}
        output={hero.terminal.output}
      />
    </div>

    <div class="hero-actions">
      <a class="hero-cta" href={hero.cta.href} download>
        {hero.cta.label}
      </a>

      <div class="social-icons">
        <a
          class="social-icon"
          href={hero.socials.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
        >
          <GithubLogo weight="fill" />
        </a>

        <a
          class="social-icon"
          href={hero.socials.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
        >
          <LinkedinLogo weight="fill" />
        </a>
      </div>
    </div>
  </div>

  <style>
    .hero {
      position: relative;
      padding-top: 6rem;
      padding-bottom: 3rem;
      overflow: hidden;
    }

    .hero-grid-bg {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      pointer-events: none;
      z-index: 0;
      background-image: 
        linear-gradient(var(--border) 1px, transparent 1px),
        linear-gradient(90deg, var(--border) 1px, transparent 1px);
      background-size: 40px 40px;
      opacity: 0.15;
      mask-image: radial-gradient(circle at 50% 30%, black 30%, transparent 80%);
      -webkit-mask-image: radial-gradient(circle at 50% 30%, black 30%, transparent 80%);
    }

    .hero-grid {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 1.75rem;
    }

    .hero-status {
      font-family: 'JetBrains Mono', monospace;
      font-weight: 400;
      color: var(--accent);
      font-size: 0.9rem;
      letter-spacing: 0.02em;
    }

    .hero-title {
      max-width: 100%;
      white-space: nowrap;
      letter-spacing: -0.02em;
    }

    .hero-intro {
      max-width: 52ch;
      font-size: 1.1rem;
      color: var(--text-muted);
      line-height: 1.7;
      text-wrap: pretty;
    }

    .terminal-wrapper {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .terminal-wrapper:hover {
      transform: translateY(-2px);
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 1.5rem;
      margin-top: 0.5rem;
    }

    .hero-cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.7rem 1.6rem;
      border: 1px solid var(--accent);
      background: var(--accent);
      color: var(--bg);
      border-radius: 6px;
      font-weight: 500;
      font-size: 0.9rem;
      text-decoration: none;
      transition: all 200ms ease;
    }

    .hero-cta:hover {
      background: transparent;
      color: var(--accent);
      transform: translateY(-2px);
    }

    .social-icons {
      display: flex;
      gap: 0.8rem;
      align-items: center;
    }

    .social-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2.4rem;
      height: 2.4rem;
      color: var(--text-muted);
      background: transparent;
      transition: all 200ms ease;
    }

    .social-icon svg {
      width: 1.5rem;
      height: 1.5rem;
      fill: currentColor;
      background: transparent;
    }

    .social-icon:hover {
      color: var(--accent);
      transform: translateY(-2px);
      background: transparent;
    }

    @media (max-width: 699px) {
      .hero {
        padding-top: 4rem;
        padding-bottom: 2rem;
      }

      .hero-title {
        white-space: normal;
        max-width: 100%;
      }

      .hero-intro {
        font-size: 1rem;
        max-width: 100%;
      }

      .hero-grid-bg {
        background-size: 30px 30px;
        opacity: 0.1;
        mask-image: radial-gradient(circle at 50% 20%, black 20%, transparent 70%);
        -webkit-mask-image: radial-gradient(circle at 50% 20%, black 20%, transparent 70%);
      }

      .hero-actions {
        flex-direction: column;
        align-items: stretch;
        gap: 1rem;
      }

      .hero-cta, .social-icon {
        justify-content: center;
      }

      .social-icons {
        justify-content: center;
        gap: 1rem;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .terminal-wrapper:hover,
      .hero-cta:hover,
      .social-icon:hover {
        transform: none;
      }
    }
  </style>
</section>