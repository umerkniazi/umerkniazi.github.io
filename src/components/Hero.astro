---
import { GithubLogo, LinkedinLogo } from '@phosphor-icons/react/dist/ssr';
---

<section class="section hero" id="hero" data-reveal>
  <div class="container hero-grid">
    <div class="hero-status">// currently: building practical systems and polishing this portfolio</div>
    <h1>Umer Khan Niazi</h1>
    <p class="title">AI Student & Systems Developer</p>
    <p class="intro">
      I'm a second-year AI student focused on building useful software, from command-line tools to small games and practical tools.
    </p>
    <div class="hero-terminal" aria-label="Terminal introduction">
      <div class="terminal-chrome" aria-hidden="true">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
      </div>
      <pre class="hero-terminal-body" aria-live="polite">
        <code class="terminal-line terminal-meta">umer@portfolio:~</code>
        <code class="terminal-line"><span class="terminal-prompt">$</span> whoami</code>
        <code
          class="terminal-line terminal-output"
          id="whoamiOutput"
          data-text="Umer Khan Niazi · AI student building practical systems with Python and C++."
        >Umer Khan Niazi · AI student building practical systems with Python and C++.</code>
      </pre>
    </div>
    <div class="hero-actions">
      <a class="hero-cta" href="/resume.pdf" download>Download CV</a>
      <a class="hero-icon-link" href="https://github.com/umerkniazi" target="_blank" rel="noreferrer" aria-label="GitHub">
        <GithubLogo className="hero-icon" aria-hidden="true" weight="duotone" />
      </a>
      <a class="hero-icon-link" href="https://linkedin.com/in/umerkniazi" target="_blank" rel="noreferrer" aria-label="LinkedIn">
        <LinkedinLogo className="hero-icon" aria-hidden="true" weight="duotone" />
      </a>
    </div>
  </div>
</section>