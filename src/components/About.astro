---
import { siteConfig } from '../config';

const { about } = siteConfig;
---

<section class="section" id="about" data-reveal>
  <div class="container narrow">
    <div class="section-heading">
      <span class="eyebrow">{about.heading.eyebrow}</span>
      <h2>{about.heading.title}</h2>
    </div>

    <div class="about-grid" style="display: grid; gap: 4rem; grid-template-columns: 1fr;">
      <div class="about-copy">
        {about.introParagraphs.map(paragraph => (
          <p>{paragraph}</p>
        ))}

        <div class="skills-grid" aria-label="Skills">
          {about.skillGroups.map(group => (
            <div class="skill-group">
              <span class="skill-label">{group.label}</span>
              <div class="skill-pills">
                {group.skills.map(skill => (
                  <span class="skill-pill">{skill}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="timeline-list">
        {about.timeline.map(item => (
          <article class={`timeline-item ${item.primary ? 'primary' : ''}`}>
            <div>
              <div class="timeline-year">{item.year}</div>
            </div>
            <div>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .section-heading {
    display: grid;
    gap: 0.55rem;
    margin-bottom: 3.5rem;
  }

  .eyebrow {
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    color: var(--accent);
    font-size: 0.84rem;
    letter-spacing: 0.02em;
  }

  .about-copy {
    display: grid;
    gap: 1.25rem;
  }

  .about-copy p {
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .skills-grid {
    display: grid;
    gap: 1.75rem;
    margin-top: 0.5rem;
  }

  .skill-group {
    display: grid;
    gap: 0.9rem;
  }

  .skill-label {
    color: var(--text);
    font-size: 0.95rem;
    font-weight: 400;
  }

  .skill-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-pill {
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    border-radius: 2px;
    letter-spacing: 0.03em;
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    transition: all var(--transition-fast);
  }

  .timeline-list {
    display: grid;
    gap: 0;
  }

  .timeline-item {
    display: grid;
    gap: 0.8rem;
    grid-template-columns: minmax(9rem, 12rem) 1fr;
    padding: 1.5rem 0;
    border-top: 1px solid var(--border);
    background: transparent;
  }

  .timeline-item:hover {
    border-color: var(--border);
    background: transparent;
    transform: none;
  }

  .timeline-item.primary {
    border-top: 1px solid var(--border);
    background: transparent;
    box-shadow: none;
  }

  .timeline-item p {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .timeline-item h3 {
    margin: 0 0 0.35rem;
    color: var(--text);
  }

  .timeline-year {
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    color: var(--text-muted);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .timeline-item.primary .timeline-year {
    color: var(--accent);
  }

  @media (max-width: 699px) {
    .timeline-item {
      grid-template-columns: 1fr;
    }
  }
</style>