---
import { siteConfig } from '../config';

const { about } = siteConfig;
---

<section class="section" id="about">
  <div class="container">
    <div class="section-heading">
      <p class="section-kicker">{about.sectionLabel}</p>
      <h2 class="section-title">I like knowing how things actually work.</h2>
      <p class="section-lede">The work leans toward understanding the mechanics, then shipping something that stays readable and maintainable.</p>
    </div>

    <div class="about-grid">
      <div class="about-intro">
        {about.introParagraphs.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>

      <div class="about-stack">
        <article class="about-card card education-card">
          <h3 class="about-heading">Education</h3>
          <div class="timeline-list">
            {about.timeline.map((item) => (
              <div class="timeline-item">
                <div class="timeline-year">{item.years}</div>
                <div class="timeline-details">
                  <h4>{item.degree}</h4>
                  <p>{item.institution}</p>
                </div>
              </div>
            ))}
          </div>
        </article>

        <article class="about-card card">
          <h3 class="about-heading">Skills</h3>
          <div class="skills-list">
            {about.skillGroups.map((group) => (
              <div class="skill-line">
                <span class="skill-label">{group.label}</span>
                <span class="skill-items">{group.skills.join(', ')}</span>
              </div>
            ))}
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(340px, 0.95fr);
    gap: var(--space-8);
    align-items: start;
  }

  .about-stack {
    display: grid;
    gap: var(--space-6);
  }

  .about-card {
    padding: var(--space-6);
  }

  .education-card {
    padding: var(--space-4) var(--space-6);
  }

  .about-heading {
    color: var(--text);
    font-size: var(--text-sm);
    margin-bottom: var(--space-5);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-family: var(--font-mono);
  }

  .about-intro {
    display: grid;
    gap: var(--space-5);
    color: var(--text-muted);
    line-height: var(--leading-normal);
  }

  .timeline-list,
  .skills-list {
    display: grid;
    gap: var(--space-4);
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: var(--space-4);
    align-items: baseline;
    padding-top: var(--space-4);
    border-top: var(--border-width-thin) solid var(--border);
  }

  .timeline-item:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .timeline-year {
    color: var(--text-subtle);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .timeline-details h4 {
    color: var(--text);
    margin-bottom: var(--space-1);
  }

  .timeline-details p {
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  .skill-line {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: var(--space-4);
    align-items: start;
    padding-top: var(--space-4);
    border-top: var(--border-width-thin) solid var(--border);
  }

  .skill-line:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .skill-label {
    color: var(--text-subtle);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .skill-items {
    color: var(--text-muted);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
  }

  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .about-card,
    .education-card {
      padding: var(--space-5);
    }

    .timeline-item {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }

    .skill-line {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
  }
</style>