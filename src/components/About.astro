---
import { siteConfig } from '../config';

const { about } = siteConfig;
const education = about.timeline.find(item => item.primary);
---

<section class="section" id="about">
  <div class="container">
    <div class="about-block">
      <h2 class="section-heading">{about.heading.title}</h2>
      <div class="about-intro">
        {about.introParagraphs.map(paragraph => (
          <p>{paragraph}</p>
        ))}
      </div>
    </div>

    <div class="about-block">
      <h2 class="section-heading">{about.heading.education}</h2>
      {education && (
        <div class="edu-layout">
          <div class="edu-year">{education.year}</div>
          <div class="edu-content">
            <h3>{education.title}</h3>
            {education.description && <p>{education.description}</p>}
          </div>
        </div>
      )}
    </div>

    <div class="about-block">
      <h2 class="section-heading">{about.heading.skills}</h2>
      <div class="skills-list">
        {about.skillGroups.map(group => (
          <div class="skill-line">
            <span class="skill-label">&gt; {group.label}</span>
            <span class="skill-items">{group.skills.join(', ')}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  #about {
    padding-top: 4rem;
  }

  .about-block {
    margin-bottom: 3.5rem;
  }

  .about-block:last-child {
    margin-bottom: 0;
  }

  .about-intro {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    color: var(--text-muted);
    max-width: 65ch;
    line-height: 1.6;
  }
  
  .edu-layout {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 2rem;
    align-items: baseline;
  }
  
  .edu-year {
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  
  .edu-content h3 {
    color: var(--text);
    margin-bottom: 0.2rem;
    font-size: 1.1rem;
    font-weight: bold;
  }
  
  .edu-content p {
    color: var(--text-muted);
    margin-top: 0.4rem;
  }
  
  .skills-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .skill-line {
    display: flex;
    gap: 1.5rem;
    align-items: baseline;
  }
  
  .skill-label {
    color: var(--accent);
    min-width: 120px;
    font-weight: bold;
    display: flex;
    align-items: center;
  }
  
  .skill-items {
    color: var(--text-muted);
  }

  @media (max-width: 600px) {
    .edu-layout {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    
    .skill-line {
      flex-direction: column;
      gap: 0.3rem;
    }

    .skill-label {
      min-width: auto;
    }
  }
</style>