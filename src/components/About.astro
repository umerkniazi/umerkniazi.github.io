---
import { siteConfig } from '../config';

const { about } = siteConfig;
---

<section class="section" id="about">
  <div class="container">
    <h2 class="label">{about.sectionLabel}</h2>

    <div class="about-content">
      <div class="about-block intro-block">
        <div class="about-intro">
          {about.introParagraphs.map(paragraph => (
            <p>{paragraph}</p>
          ))}
        </div>
      </div>

      <div class="about-block">
        <h3 class="sub-heading">Education</h3>
        <div class="timeline-list">
          {about.timeline.map(item => (
            <div class="timeline-item">
              <div class="timeline-year">{item.years}</div>
              <div class="timeline-details">
                <h4>{item.degree}</h4>
                <p>{item.institution}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="about-block">
        <h3 class="sub-heading">Skills</h3>
        <div class="skills-list">
          {about.skillGroups.map(group => (
            <div class="skill-line">
              <span class="skill-label">&gt; {group.label}</span>
              <span class="skill-items">{group.skills.join(', ')}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-content {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .sub-heading {
    color: var(--text);
    font-size: 1.1rem;
    margin-bottom: 2rem;
    font-weight: 600;
  }

  .about-intro {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    color: var(--text-muted);
    max-width: 65ch;
  }
  
  .timeline-item {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 2rem;
    align-items: baseline;
  }
  
  .timeline-year {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }
  
  .timeline-details h4 {
    color: var(--text);
    font-size: 1.05rem;
    margin-bottom: 0.25rem;
  }
  
  .timeline-details p {
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  
  .skills-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  
  .skill-line {
    display: flex;
    gap: 1.5rem;
    align-items: baseline;
  }
  
  .skill-label {
    color: var(--accent);
    font-family: var(--font-mono);
    min-width: 120px;
    font-weight: 600;
    font-size: 0.9rem;
  }
  
  .skill-items {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  @media (max-width: 600px) {
    .timeline-item {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
    
    .skill-line {
      flex-direction: column;
      gap: 0.25rem;
    }

    .skill-label {
      min-width: auto;
    }
  }
</style>