---
import { EnvelopeSimple, GithubLogo, LinkedinLogo } from '@phosphor-icons/react/dist/ssr';
import { siteConfig } from '../config';

const { contact } = siteConfig;

const iconMap = {
  EnvelopeSimple: EnvelopeSimple,
  GithubLogo: GithubLogo,
  LinkedinLogo: LinkedinLogo
};
---

<section class="section" id="contact" data-reveal style="padding-bottom: 2rem;">
  <div class="container narrow">
    <div class="section-heading">
      <span class="eyebrow">{contact.heading.eyebrow}</span>
      <h2>{contact.heading.title}</h2>
      <p class="section-lead">{contact.heading.lead}</p>
    </div>

    <div class="contact-list">
      {contact.contacts.map(item => {
        const Icon = iconMap[item.icon];
        return (
          <a href={item.href} target={item.external ? "_blank" : undefined} rel={item.external ? "noreferrer" : undefined}>
            <strong class="contact-label">
              {Icon && <Icon className="contact-icon" aria-hidden="true" weight="duotone" />}
              {item.label}
            </strong>
            <span class="contact-value">{item.value}</span>
          </a>
        );
      })}
    </div>
  </div>
</section>

<style>
  .section-heading {
    display: grid;
    gap: 0.55rem;
    margin-bottom: 3.5rem;
  }

  .eyebrow {
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    color: var(--accent);
    font-size: 0.84rem;
    letter-spacing: 0.02em;
  }

  .section-lead {
    margin: 0;
    color: var(--text-muted);
    font-size: 1.02rem;
    line-height: 1.7;
    max-width: 60ch;
  }

  .contact-list {
    display: grid;
    gap: 1rem;
    max-width: 600px;
    width: 100%;
  }

  .contact-list a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 0;
    border: none;
    border-bottom: 1px solid var(--border);
    background: transparent;
  }

  .contact-list a:hover {
    border-color: var(--text-muted);
  }

  .contact-label {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    min-width: 0;
    font-weight: 500;
    color: var(--text);
  }

  .contact-value {
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 400;
  }

  .contact-list a:hover .contact-value {
    color: var(--text);
  }

  .contact-icon {
    flex: 0 0 auto;
    width: 1.1rem;
    height: 1.1rem;
    color: var(--text-muted);
  }

  @media (max-width: 699px) {
    .contact-list a {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
</style>