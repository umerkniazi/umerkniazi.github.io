---
import { ArrowUpRight, GithubLogo } from '@phosphor-icons/react/dist/ssr';
---
<section class="section" id="projects" data-reveal>
  <div class="container">
    <div class="section-heading">
      <span class="eyebrow">// projects</span>
      <h2>Featured Work</h2>
    </div>
    <div class="projects-grid">
      <article class="project-card featured">
        <div class="project-kicker">Featured</div>
        <figure class="project-media">
          <img src="/images/news-nlp-pipeline.png" alt="News NLP Pipeline project screenshot" width="1280" height="720" loading="lazy" decoding="async" />
        </figure>
        <h3>News NLP Pipeline</h3>
        <p>
          Processes and classifies 350k+ news articles from Dawn using an automated NLP pipeline. Built with Python and BERTopic to perform sentiment analysis, named entity recognition, and topic modeling at scale.
        </p>
        <p class="tech-stack" aria-label="Project tags">
          <span class="tech-pill">Python</span>
          <span class="tech-pill">NLP</span>
          <span class="tech-pill">BERTopic</span>
          <span class="tech-pill">scikit-learn</span>
          <span class="tech-pill">spaCy / NLTK</span>
        </p>
        <div class="project-links">
          <a href="https://news-nlp-pipeline.streamlit.app/" target="_blank" rel="noreferrer">
            <ArrowUpRight aria-hidden="true" weight="bold" /> Live Demo
          </a>
          <a href="https://github.com/umerkniazi/news-nlp-pipeline" target="_blank" rel="noreferrer">
            <GithubLogo aria-hidden="true" weight="bold" /> GitHub
          </a>
        </div>
      </article>

      <article class="project-card featured">
        <div class="project-kicker">Featured</div>
        <figure class="project-media">
          <img src="/images/shelter-outcome-predictor.png" alt="Shelter Outcome Predictor project screenshot" width="1280" height="720" loading="lazy" decoding="async" />
        </figure>
        <h3>Shelter Outcome Predictor</h3>
        <p>
          Predicts adoption and euthanasia risks for shelter animals using a Random Forest classifier trained on 62k+ real intake records. Deployed as a high-recall Streamlit application to assist in shelter triage operations.
        </p>
        <p class="tech-stack" aria-label="Project tags">
          <span class="tech-pill">Python</span>
          <span class="tech-pill">Machine Learning</span>
          <span class="tech-pill">scikit-learn</span>
          <span class="tech-pill">Streamlit</span>
        </p>
        <div class="project-links">
          <a href="https://shelter-outcome-predictor.streamlit.app/" target="_blank" rel="noreferrer">
            <ArrowUpRight aria-hidden="true" weight="bold" /> Live Demo
          </a>
          <a href="https://github.com/umerkniazi/shelter-outcome-predictor" target="_blank" rel="noreferrer">
            <GithubLogo aria-hidden="true" weight="bold" /> GitHub
          </a>
        </div>
      </article>

      <article class="project-card featured">
        <div class="project-kicker">Featured</div>
        <figure class="project-media">
          <img src="/images/wmus-screenshot.png" alt="WMUS project screenshot" width="1280" height="720" loading="lazy" decoding="async" />
        </figure>
        <h3>WMUS</h3>
        <p>
          Powers seamless terminal-based audio playback through a lightweight, Cmus-inspired music player. Engineered with Python to feature fast metadata caching, fuzzy search, and vim-style navigation.
        </p>
        <p class="tech-stack" aria-label="Project tags">
          <span class="tech-pill">Python</span>
          <span class="tech-pill">CLI Tool</span>
          <span class="tech-pill">Systems Programming</span>
        </p>
        <div class="project-links">
          <a href="https://github.com/umerkniazi/wmus" target="_blank" rel="noreferrer">
            <GithubLogo aria-hidden="true" weight="bold" /> GitHub
          </a>
        </div>
      </article>

      <article class="project-card">
        <div class="project-kicker">Other</div>
        <figure class="project-media">
          <img src="/images/waddle-away-screenshot.png" alt="Waddle Away project screenshot" width="1280" height="720" loading="lazy" decoding="async" />
        </figure>
        <h3>Waddle Away</h3>
        <p>
          Delivers a responsive 2D endless runner experience built in Godot, optimizing for tight gameplay feel and smooth collision mechanics.
        </p>
        <p class="tech-stack" aria-label="Project tags">
          <span class="tech-pill">Godot</span>
          <span class="tech-pill">Game Development</span>
        </p>
        <div class="project-links">
          <a href="https://umerkniazi.itch.io/waddle-away" target="_blank" rel="noreferrer">
            <ArrowUpRight aria-hidden="true" weight="bold" /> Play
          </a>
          <a href="https://github.com/umerkniazi/waddle-away" target="_blank" rel="noreferrer">
            <GithubLogo aria-hidden="true" weight="bold" /> GitHub
          </a>
        </div>
      </article>
    </div>
  </div>
</section>