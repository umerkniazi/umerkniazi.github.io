---
import { siteConfig } from '../config';
import { IconBrandGithub, IconExternalLink, IconChevronDown } from '@tabler/icons-react';

const { sectionLabel, items } = siteConfig.projects;
---

<section id="projects" class="section">
  <div class="container">
    <div class="section-heading">
      <p class="section-kicker">{sectionLabel}</p>
      <h2 class="section-title">Things I've built.</h2>
      <p class="section-lede">Projects shaped around systems, measurement, and a clear view of failure modes.</p>
    </div>

    <div class="projects-list">
      {items.map((project) => (
        <article class="project-card card card-strong">
          <div class="project-top">
            <div class="project-copy">
              <h3 class="project-title">{project.title}</h3>
              {project.subtitle && <p class="project-subtitle">{project.subtitle}</p>}
              <p class="project-desc">{project.description}</p>
            </div>

            <div class="project-tags" aria-label="Technologies used">
              {project.tags.map((tag) => (
                <span class="chip project-tag">{tag}</span>
              ))}
            </div>
          </div>

          <dl class="project-facts">
            {project.dataset && (
              <div class="project-fact">
                <dt>Data</dt>
                <dd>{project.dataset}</dd>
              </div>
            )}
            <div class="project-fact">
              <dt>Result</dt>
              <dd>{project.outcome}</dd>
            </div>
          </dl>

          {project.highlight && <p class="project-highlight">{project.highlight}</p>}

          <details class="project-detail">
            <summary class="detail-toggle">
              <span>Technical details</span>
              <IconChevronDown className="detail-icon" stroke={1.8} aria-hidden="true" />
            </summary>
            <dl class="detail-grid">
              <dt>Problem</dt>
              <dd>{project.detail.problem}</dd>
              <dt>Approach</dt>
              <dd>{project.detail.approach}</dd>
              <dt>Result</dt>
              <dd>{project.detail.result}</dd>
            </dl>
          </details>

          {project.links && project.links.length > 0 && (
            <div class="project-links">
              {project.links.map((link) => (
                <a
                  href={link.href}
                  class={`project-link ${link.label.toLowerCase() !== 'github' ? 'primary' : ''}`}
                  {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {link.label.toLowerCase() === 'github' ? (
                    <IconBrandGithub size={18} stroke={1.5} aria-hidden="true" />
                  ) : (
                    <IconExternalLink size={18} stroke={1.5} aria-hidden="true" />
                  )}
                  <span>{link.label}</span>
                </a>
              ))}
            </div>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding: var(--space-6);
  }

  .project-card:hover {
    border-color: var(--border-strong);
  }

  .project-top {
    display: flex;
    justify-content: space-between;
    gap: var(--space-6);
    align-items: start;
  }

  .project-copy {
    display: grid;
    gap: var(--space-3);
  }

  .project-title {
    color: var(--text);
  }

  .project-subtitle {
    color: var(--text-subtle);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .project-desc {
    color: var(--text-muted);
    line-height: var(--leading-normal);
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    justify-content: flex-end;
    max-width: 22rem;
  }

  .project-tag {
    white-space: nowrap;
  }

  .project-facts {
    display: grid;
    gap: var(--space-3);
  }

  .project-fact {
    display: grid;
    grid-template-columns: 5rem minmax(0, 1fr);
    gap: var(--space-4);
    align-items: start;
    padding-top: var(--space-3);
    border-top: var(--border-width-thin) solid var(--border);
  }

  .project-fact dt {
    color: var(--text-subtle);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .project-fact dd {
    color: var(--text-muted);
    margin: 0;
    line-height: var(--leading-normal);
  }

  .project-highlight {
    color: var(--text-muted);
    padding: var(--space-4);
    border-left: var(--border-width-medium) solid var(--accent);
    background: var(--surface-alt);
    font-size: var(--text-sm);
  }

  .project-detail {
    border: var(--border-width-thin) solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--surface);
    overflow: hidden;
  }

  .detail-toggle {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-3) var(--space-4);
    cursor: pointer;
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    color: var(--text-muted);
    user-select: none;
  }

  .detail-toggle:hover {
    color: var(--text);
    background-color: var(--surface-alt);
  }

  .detail-toggle::-webkit-details-marker { display: none; }
  .project-detail > summary { list-style: none; }

  .detail-icon {
    width: 1rem;
    height: 1rem;
    transition: transform var(--duration-base) var(--ease-standard);
  }

  details[open] .detail-icon {
    transform: rotate(180deg);
  }

  .detail-grid {
    display: grid;
    grid-template-columns: var(--size-column-narrow) 1fr;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-4);
    border-top: var(--border-width-thin) solid var(--border);
    font-size: var(--text-sm);
  }

  .detail-grid dt {
    color: var(--text);
    font-weight: 600;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .detail-grid dd {
    color: var(--text-muted);
    margin: 0;
    line-height: var(--leading-normal);
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    font-size: var(--text-sm);
    font-family: var(--font-mono);
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    min-height: 40px;
    padding: 0 var(--space-3);
    border: var(--border-width-thin) solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--surface);
    color: var(--text-muted);
  }

  .project-link:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--surface-alt);
  }

  .project-link.primary {
    color: var(--accent);
  }

  .project-link.primary:hover {
    color: var(--accent-hover);
  }

  @media (max-width: 720px) {
    .project-card {
      padding: var(--space-5);
    }

    .project-top {
      flex-direction: column;
    }

    .project-tags {
      justify-content: flex-start;
      max-width: none;
    }

    .detail-grid {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }

    .detail-grid dt {
      margin-bottom: calc(var(--space-1) * -1);
    }

    .project-fact {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
  }
</style>