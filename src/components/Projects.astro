---
import { ArrowUpRight, GithubLogo, GameController } from '@phosphor-icons/react/dist/ssr';
import { siteConfig } from '../config';

const { projects } = siteConfig;

const iconMap = {
  GithubLogo: GithubLogo,
  ArrowUpRight: ArrowUpRight,
  GameController: GameController
};
---

<section class="section" id="projects">
  <div class="container narrow">
    <div class="section-heading">
      <span class="eyebrow">{projects.heading.eyebrow}</span>
      <h2>{projects.heading.title}</h2>
    </div>

    <div class="projects-list">
      {projects.featured.map(project => (
        <article class={`project-item ${project.isFlagship ? 'flagship' : ''}`}>
          <div class="project-header">
            <div class="project-kicker"><strong>{project.kicker}</strong></div>
            <h3>{project.title}</h3>
            {project.metricBadge && <div class="project-metric-badge">{project.metricBadge}</div>}
          </div>
          <p>{project.description}</p>
          <p class="tech-stack" aria-label="Project tags">
            {project.techStack.map(tech => <span class="tech-pill">{tech}</span>)}
          </p>
          <div class="project-links">
            {project.links.map(link => {
              const Icon = iconMap[link.icon];
              return (
                <a href={link.url} target="_blank" rel="noopener noreferrer">
                  {Icon && <Icon aria-hidden="true" weight="bold" />}
                  {link.label}
                </a>
              );
            })}
          </div>
        </article>
      ))}

      <div class="secondary-projects-heading">
        <span class="eyebrow">{projects.secondaryHeading.eyebrow}</span>
      </div>

      {projects.other.map(project => (
        <article class={`project-item ${project.isSideProject ? 'side-project' : ''}`}>
          <div class="project-header">
            <div class="project-kicker"><strong>{project.kicker}</strong></div>
            <h3>{project.title}</h3>
          </div>
          <p>{project.description}</p>
          <p class="tech-stack" aria-label="Project tags">
            {project.techStack.map(tech => <span class="tech-pill">{tech}</span>)}
          </p>
          <div class="project-links">
            {project.links.map(link => {
              const Icon = iconMap[link.icon];
              return (
                <a href={link.url} target="_blank" rel="noopener noreferrer">
                  {Icon && <Icon aria-hidden="true" weight="bold" />}
                  {link.label}
                </a>
              );
            })}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .section-heading {
    display: grid;
    gap: 0.55rem;
    margin-bottom: 2.5rem;
  }

  .eyebrow {
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    color: var(--accent);
    font-size: 0.84rem;
    letter-spacing: 0.02em;
  }

  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
    max-width: 680px;
    border-top: 1px solid var(--border);
    padding-top: 3rem;
  }

  .project-item {
    border: none;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
    display: flex;
    flex-direction: column;
    gap: 1.15rem;
    transition: none;
  }

  .project-item:hover {
    transform: none;
    background: transparent;
    box-shadow: none;
  }

  .project-header {
    display: flex;
    flex-direction: column;
  }

  .project-kicker,
  .project-kicker strong {
    font-family: var(--font-serif) !important;
    font-style: italic !important;
    font-weight: 300 !important;
    font-size: 1.1rem !important;
    color: var(--accent) !important;
    opacity: 0.85;
    border: none;
    padding: 0;
    text-transform: none;
    letter-spacing: normal;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    width: auto;
    justify-self: start;
    align-self: start;
    margin-bottom: 0.5rem;
    white-space: normal;
  }

  .project-metric-badge {
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    display: inline-flex;
    align-items: center;
    width: fit-content;
    background: var(--surface-strong);
    color: var(--text);
    font-size: 0.75rem;
    padding: 0.25rem 0.6rem;
    border-radius: 2px;
    margin-top: 0.75rem;
    letter-spacing: 0.02em;
    border: 1px solid var(--border);
  }

  .project-item h3 {
    font-size: 1.75rem;
    font-weight: 500;
    color: var(--text);
    margin: 0;
  }

  .project-item > p {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.75;
    margin: 0;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin: 0;
  }

  .tech-pill {
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    border-radius: 2px;
    letter-spacing: 0.03em;
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    transition: all var(--transition-fast);
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-top: 0.25rem;
  }

  .project-links a {
    color: var(--text-muted);
    font-weight: 400;
    font-size: 0.94rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .project-item:hover .project-links a {
    color: var(--accent);
  }

  .project-links a:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .secondary-projects-heading {
    border-top: 1px dashed var(--border);
    padding-top: 2.5rem;
    margin-top: -0.5rem;
  }
</style>