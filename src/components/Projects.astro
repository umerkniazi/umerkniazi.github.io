---
import { ArrowUpRight, GithubLogo, GameController } from '@phosphor-icons/react/dist/ssr';
import { siteConfig } from '../config';

const { projects } = siteConfig;

const iconMap = {
  GithubLogo: GithubLogo,
  ArrowUpRight: ArrowUpRight,
  GameController: GameController
};
---

<section class="section" id="projects">
  <div class="container narrow">
    <div class="section-heading">
      <span class="eyebrow">{projects.heading.eyebrow}</span>
      <h2>{projects.heading.title}</h2>
    </div>

    <div class="projects-list">
      {projects.featured.map(project => (
        <article class={`project-item ${project.isFlagship ? 'flagship' : ''}`}>
          <div class="project-header">
            <div class="project-kicker"><strong>{project.kicker}</strong></div>
            <div class="title-row">
              <h3>{project.title}</h3>
              {project.metricBadge && <span class="metric-pill">{project.metricBadge}</span>}
            </div>
          </div>
          <p class="project-description">{project.description}</p>
          <p class="tech-stack" aria-label="Project tags">
            {project.techStack.map(tech => <span class="tech-pill">{tech}</span>)}
          </p>
          <div class="project-links">
            {project.links.map(link => {
              const Icon = iconMap[link.icon];
              return (
                <a href={link.url} target="_blank" rel="noopener noreferrer">
                  {Icon && <Icon aria-hidden="true" weight="bold" />}
                  {link.label}
                </a>
              );
            })}
          </div>
        </article>
      ))}

      <div class="secondary-projects-heading">
        <span class="eyebrow">{projects.secondaryHeading.eyebrow}</span>
      </div>

      {projects.other.map(project => (
        <article class="project-item compact">
          <div class="project-header">
            <div class="project-kicker"><strong>{project.kicker}</strong></div>
            <h3>{project.title}</h3>
          </div>
          <p class="project-description">{project.description}</p>
          <p class="tech-stack" aria-label="Project tags">
            {project.techStack.map(tech => <span class="tech-pill">{tech}</span>)}
          </p>
          <div class="project-links">
            {project.links.map(link => {
              const Icon = iconMap[link.icon];
              return (
                <a href={link.url} target="_blank" rel="noopener noreferrer">
                  {Icon && <Icon aria-hidden="true" weight="bold" />}
                  {link.label}
                </a>
              );
            })}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .section-heading {
    display: grid;
    gap: 0.55rem;
    margin-bottom: 2.5rem;
  }

  .eyebrow {
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    color: var(--accent);
    font-size: 0.84rem;
    letter-spacing: 0.02em;
  }

  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
    max-width: 680px;
    border-top: 1px solid var(--border);
    padding-top: 3rem;
  }

  .project-item {
    border: none;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: none;
  }

  .project-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .title-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .project-kicker,
  .project-kicker strong {
    font-family: var(--font-serif) !important;
    font-style: italic !important;
    font-weight: 300 !important;
    font-size: 1rem !important;
    color: var(--accent) !important;
    opacity: 0.85;
    border: none;
    padding: 0;
    text-transform: none;
    letter-spacing: normal;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    width: auto;
    align-self: start;
    margin-bottom: 0;
    white-space: normal;
  }

  .metric-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'JetBrains Mono', monospace;
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
    white-space: nowrap;
    letter-spacing: 0.01em;
  }

  .project-item h3 {
    font-size: 1.6rem;
    font-weight: 500;
    color: var(--text);
    margin: 0;
    flex: 1;
  }

  .project-description {
    color: var(--text-muted);
    font-size: 0.98rem;
    line-height: 1.7;
    margin: 0;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin: 0.25rem 0 0;
  }

  .tech-pill {
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.7rem;
    padding: 0.2rem 0.6rem;
    border-radius: 2px;
    letter-spacing: 0.03em;
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    transition: all var(--transition-fast);
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-top: 0.25rem;
  }

  .project-links a {
    color: var(--text-muted);
    font-weight: 400;
    font-size: 0.88rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    transition: all var(--transition-fast);
  }

  .project-links a:hover {
    color: var(--accent);
  }

  .secondary-projects-heading {
    border-top: 1px dashed var(--border);
    padding-top: 2rem;
    margin-top: -0.5rem;
  }

  .secondary-projects-heading .eyebrow {
    font-size: 0.9rem;
    font-weight: 500;
  }

  /* Compact projects (other work) */
  .project-item.compact {
    gap: 0.5rem;
  }

  .project-item.compact h3 {
    font-size: 1.2rem;
    font-weight: 500;
  }

  .project-item.compact .project-description {
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .project-item.compact .tech-stack {
    gap: 0.4rem;
    margin-top: 0;
  }

  .project-item.compact .tech-pill {
    font-size: 0.65rem;
    padding: 0.15rem 0.5rem;
  }

  .project-item.compact .project-links {
    margin-top: 0;
    gap: 1rem;
  }

  .project-item.compact .project-links a {
    font-size: 0.8rem;
  }

  @media (max-width: 699px) {
    .projects-list {
      gap: 2.5rem;
      padding-top: 2rem;
    }
    .title-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
    .metric-pill {
      white-space: normal;
      font-size: 0.65rem;
    }
    .project-item h3 {
      font-size: 1.4rem;
    }
    .project-description {
      font-size: 0.92rem;
    }
    .project-item.compact h3 {
      font-size: 1.1rem;
    }
    .project-item.compact .project-description {
      font-size: 0.85rem;
    }
  }
</style>