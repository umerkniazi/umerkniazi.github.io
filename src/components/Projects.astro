---
import { ArrowUpRight, GithubLogo } from '@phosphor-icons/react/dist/ssr';
import { siteConfig } from '../config';

const { projects } = siteConfig;

const iconMap = {
  GithubLogo: GithubLogo,
  ArrowUpRight: ArrowUpRight
};
---

<section class="section" id="projects">
  <div class="container narrow">
    <div class="section-heading">
      <span class="eyebrow">{projects.heading.eyebrow}</span>
      <h2>{projects.heading.title}</h2>
    </div>

    <div class="projects-list">
      {projects.featured.map(project => (
        <article class="project-item">
          <div class="project-meta">
            <div class="project-kicker"><strong>{project.kicker}</strong></div>
            {project.metricBadge && <span class="metric-badge">{project.metricBadge}</span>}
          </div>
          <h3>{project.title}</h3>
          <p class="project-description">{project.description}</p>
          <div class="tech-stack">
            {project.techStack.map(tech => <span class="tech-pill">{tech}</span>)}
          </div>
          <div class="project-links">
            {project.links.map(link => {
              const Icon = iconMap[link.icon];
              return (
                <a href={link.url} target="_blank" rel="noopener noreferrer">
                  {Icon && <Icon aria-hidden="true" weight="fill" />}
                  {link.label}
                </a>
              );
            })}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .section-heading {
    display: grid;
    gap: 0.55rem;
    margin-bottom: 2.5rem;
  }

  .eyebrow {
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    color: var(--accent);
    font-size: 0.84rem;
    letter-spacing: 0.02em;
  }

  .projects-list {
    display: flex;
    flex-direction: column;
    max-width: 680px;
    border-top: 1px solid var(--border);
    padding-top: 3rem;
  }

  .project-item {
    margin-bottom: 2.5rem;
  }
  .project-item:last-child {
    margin-bottom: 0;
  }

  .project-item {
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.008);
    border-radius: 16px;
    padding: 1.5rem;
    transition: all 0.2s ease;
  }

  .project-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .project-kicker {
    display: inline-flex;
    align-items: baseline;
  }
  .project-kicker,
  .project-kicker strong {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 300;
    font-size: 1rem;
    color: var(--accent);
    opacity: 0.85;
    margin: 0;
  }

  .metric-badge {
    display: inline-flex;
    align-items: center;
    font-family: 'JetBrains Mono', monospace;
    background: color-mix(in srgb, var(--accent) 20%, transparent);
    color: var(--accent);
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.2rem 0.7rem;
    border-radius: 20px;
    border: 1px solid color-mix(in srgb, var(--accent) 60%, transparent);
    line-height: 1.3;
    white-space: nowrap;
  }

  .project-item h3 {
    font-size: 1.6rem;
    font-weight: 500;
    color: var(--text);
    margin: 0 0 0.75rem;
  }

  .project-description {
    color: var(--text-muted);
    font-size: 0.98rem;
    line-height: 1.7;
    margin: 0 0 1rem;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 1rem;
  }
  .tech-pill {
    font-family: 'JetBrains Mono', monospace;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.7rem;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    letter-spacing: 0.02em;
    transition: all var(--transition-fast);
    line-height: 1.3;
  }
  .tech-pill:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }
  .project-links a {
    color: var(--text-muted);
    font-weight: 400;
    font-size: 0.88rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    transition: all var(--transition-fast);
  }
  .project-links a svg {
    width: 1rem;
    height: 1rem;
  }
  .project-links a:hover {
    color: var(--accent);
  }

  @media (max-width: 699px) {
    .project-item {
      margin-bottom: 2rem;
      padding: 1rem;
    }
    .project-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.4rem;
    }
    .metric-badge {
      white-space: normal;
      font-size: 0.65rem;
    }
    .project-item h3 {
      font-size: 1.4rem;
    }
    .project-description {
      font-size: 0.92rem;
    }
  }
</style>