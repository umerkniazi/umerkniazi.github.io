---
import { site } from '../data/site.js';
---

<ul class="flex items-center gap-4" aria-label="Elsewhere">
  {
    site.socials.map((link) => (
      <li>
        <a
          href={link.url}
          target="_blank"
          rel="noreferrer"
          aria-label={link.label}
          title={link.label}
          class="text-sm text-faint underline-offset-4 hover:text-accent hover:underline transition-colors duration-75"
        >
          {link.label.toLowerCase()}
        </a>
      </li>
    ))
  }
</ul>