---
import { siteConfig } from '../config';
import { IconBrandGithub, IconBrandLinkedin, IconMail, IconLink } from '@tabler/icons-react';

const { footer } = siteConfig;
const isAvailable = footer.availability.available;
---

<footer class="site-footer section" id="footer">
  <div class="container">
    <div class="footer-shell card">
      <div class="footer-status">
        <span class={`dot ${isAvailable ? 'dot-available' : 'dot-unavailable'}`} aria-hidden="true"></span>
        <p>{footer.availability.label}</p>
      </div>

      <nav class="footer-links" aria-label="Footer navigation">
        {footer.contacts.map((contact) => {
          const lowerLabel = contact.label.toLowerCase();
          let Icon = IconLink;

          if (lowerLabel.includes('github')) {
            Icon = IconBrandGithub;
          } else if (lowerLabel.includes('linkedin')) {
            Icon = IconBrandLinkedin;
          } else if (lowerLabel.includes('email') || lowerLabel.includes('mail')) {
            Icon = IconMail;
          }

          return (
            <a
              href={contact.href}
              target={contact.external ? '_blank' : undefined}
              rel={contact.external ? 'noopener noreferrer' : undefined}
              class="footer-link button"
              aria-label={contact.label}
              title={contact.label}
            >
              <Icon size={18} stroke={1.7} aria-hidden="true" />
              <span>{contact.label}</span>
            </a>
          );
        })}
      </nav>

      {footer.meta && (
        <div class="footer-meta">
          <p>{footer.meta}</p>
        </div>
      )}
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    padding-top: 0;
    padding-bottom: var(--space-16);
  }

  .footer-shell {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding: var(--space-6);
  }

  .footer-status {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--text);
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .dot {
    width: var(--space-2);
    height: var(--space-2);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .dot-available {
    background-color: var(--accent);
  }

  .dot-unavailable {
    background-color: var(--text-subtle);
  }

  .footer-links {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    align-items: center;
  }

  .footer-link {
    color: var(--text-muted);
    gap: var(--space-2);
    min-width: 8.5rem;
  }

  .footer-link span {
    font-size: var(--text-sm);
  }

  .footer-link:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--surface-alt);
  }

  .footer-meta {
    color: var(--text-muted);
    font-size: var(--text-xs);
    margin-top: var(--space-2);
  }

  @media (min-width: 721px) {
    .footer-shell {
      flex-direction: row;
      justify-content: flex-start;
      gap: var(--space-8);
      align-items: center;
    }

    .footer-meta {
      margin-top: 0;
      text-align: right;
      max-width: 24rem;
      margin-left: auto;
    }
  }
</style>