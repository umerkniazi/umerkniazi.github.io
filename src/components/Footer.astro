---
import { siteConfig } from '../config';
import { IconBrandGithub, IconBrandLinkedin, IconMail, IconLink } from '@tabler/icons-react';

const { footer } = siteConfig;
---

<footer class="site-footer section" id="footer">
  <div class="container">
    <div class="footer-inner">
      <div class="status-indicator">
        <span class={`dot ${footer.availability.available ? 'pulse' : ''}`} aria-hidden="true"></span>
        <p>{footer.availability.label}</p>
      </div>
      
      <nav class="footer-links" aria-label="Footer navigation">
        {footer.contacts.map(c => {
          // Dynamically map standard text labels to their respective icons
          const lowerLabel = c.label.toLowerCase();
          let Icon = IconLink; // Generic fallback icon
          
          if (lowerLabel.includes('github')) Icon = IconBrandGithub;
          else if (lowerLabel.includes('linkedin')) Icon = IconBrandLinkedin;
          else if (lowerLabel.includes('email') || lowerLabel.includes('mail')) Icon = IconMail;

          return (
            <a 
              href={c.href} 
              target={c.external ? "_blank" : undefined}
              rel={c.external ? "noopener noreferrer" : undefined}
              class="footer-link"
              aria-label={c.label}
              title={c.label}
            >
              <Icon size={24} stroke={1.5} aria-hidden="true" />
            </a>
          );
        })}
      </nav>

      {footer.meta && (
        <div class="footer-meta">
          <p>{footer.meta}</p>
        </div>
      )}
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    border-top: 1px solid var(--border);
    padding-top: 3rem;
    padding-bottom: 3rem;
  }
  
  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    text-align: center;
  }
  
  .status-indicator {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: var(--text-muted);
    font-size: 0.9rem;
  }
  
  .dot {
    width: 8px;
    height: 8px;
    background-color: var(--accent);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .pulse {
    animation: pulse-ring 2s infinite ease-in-out;
  }

  @keyframes pulse-ring {
    0% { transform: scale(0.95); box-shadow: 0 0 0 0 color-mix(in srgb, var(--accent) 70%, transparent); }
    70% { transform: scale(1); box-shadow: 0 0 0 6px color-mix(in srgb, var(--accent) 0%, transparent); }
    100% { transform: scale(0.95); box-shadow: 0 0 0 0 transparent; }
  }
  
  .footer-links {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
  }
  
  .footer-link {
    color: var(--text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  /* Added hover effect to make the icons pop interactively */
  .footer-link:hover {
    color: var(--text);
    transform: translateY(-2px);
  }
  
  .footer-meta {
    color: var(--text-muted);
    font-size: 0.8rem;
    margin-top: 1rem;
  }
</style>