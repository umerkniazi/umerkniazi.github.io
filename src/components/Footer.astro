---
import SocialLinks from './SocialLinks.astro';
import { site } from '../data/site.js';
const year = new Date().getFullYear();
---

<footer class="flex flex-col gap-12 border-t border-border py-8 text-xs text-faint">
  <a href={`mailto:${site.email}`} class="font-mono text-muted underline-offset-4 hover:text-accent hover:underline">
    {site.email}
  </a>
  
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <p>© {year} {site.name}. Built with Astro.</p>
    <SocialLinks />
  </div>
</footer>