---
import { IconSun, IconMoon, IconMenu2, IconX } from '@tabler/icons-react';
import { siteConfig } from '../config';

const { navbar } = siteConfig;
---

<header class="site-header">
  <div class="container">
    <div class="header-inner">
      <nav class="site-nav" id="siteNav">
        <div class="nav-links">
          {navbar.links.map(link => (
            <a href={link.href}>{link.label}</a>
          ))}
          <a href={navbar.resume.href} target="_blank" rel="noopener noreferrer">{navbar.resume.label}</a>
        </div>
      </nav>

      <div class="controls">
        <button class="theme-icon-btn" id="themeToggle" type="button" aria-label="Toggle color theme">
          <IconSun className="theme-btn-icon theme-btn-icon--light" stroke={2} />
          <IconMoon className="theme-btn-icon theme-btn-icon--dark" stroke={2} />
        </button>
        
        <button id="menuToggle" class="menu-toggle" aria-expanded="false" aria-label="Toggle menu">
          <IconMenu2 className="menu-icon-open" stroke={2} />
          <IconX className="menu-icon-close" stroke={2} />
        </button>
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: background-color 0.2s ease;
  }

  .header-inner {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem 0;
  }

  .controls {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .menu-toggle,
  .theme-icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0.5rem;
    transition: color 0.2s ease;
    line-height: 1;
    outline: none;
    border-radius: 2px;
  }

  .menu-toggle:hover,
  .menu-toggle:focus-visible,
  .theme-icon-btn:hover,
  .theme-icon-btn:focus-visible {
    color: var(--text);
  }

  .menu-toggle:focus-visible,
  .theme-icon-btn:focus-visible {
    box-shadow: 0 0 0 2px var(--text-muted);
  }

  .theme-btn-icon,
  .menu-icon-open,
  .menu-icon-close {
    width: 1.2rem;
    height: 1.2rem;
  }

  .menu-icon-close {
    display: none;
  }

  :global(.nav-open) .menu-icon-open {
    display: none;
  }

  :global(.nav-open) .menu-icon-close {
    display: block;
  }
  
  .site-nav {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  
  .nav-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
  }
  
  .nav-links a {
    color: var(--text-muted);
    background: transparent;
    border: none;
    font-family: inherit;
    font-size: 1rem;
    cursor: pointer;
    padding: 0.2rem 0;
    transition: color 0.2s ease;
    text-decoration: none;
    outline: none;
  }
  
  .nav-links a:hover,
  .nav-links a:focus-visible {
    color: var(--accent);
  }

  .nav-links a:focus-visible {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .theme-btn-icon--dark { display: block; }
  .theme-btn-icon--light { display: none; }

  :global([data-theme='dark']) .theme-btn-icon--dark { display: none; }
  :global([data-theme='dark']) .theme-btn-icon--light { display: block; }

  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme='light'])) .theme-btn-icon--dark { display: none; }
    :global(:root:not([data-theme='light'])) .theme-btn-icon--light { display: block; }
  }

  @media (max-width: 600px) {
    .header-inner {
      flex-direction: column;
      gap: 0;
    }

    .controls {
      width: 100%;
      justify-content: flex-end;
    }

    .menu-toggle {
      display: inline-flex;
    }

    .site-nav {
      display: none;
      width: 100%;
      padding-top: 1rem;
    }

    :global(.nav-open) .site-nav {
      display: flex;
    }

    .nav-links {
      flex-direction: column;
      gap: 1.25rem;
      width: 100%;
      justify-content: flex-start;
      align-items: flex-start;
    }

    :global(.nav-open) .theme-icon-btn {
      display: none;
    }
  }

  @media (min-width: 601px) {
    .menu-toggle {
      display: none;
    }

    .header-inner {
      justify-content: space-between;
    }

    .site-nav {
      justify-content: flex-start;
    }

    .nav-links {
      justify-content: flex-start;
    }
  }
</style>