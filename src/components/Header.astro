---
import { Sun, Moon, List, X } from '@phosphor-icons/react/dist/ssr';
import { siteConfig } from '../config';
const { navbar } = siteConfig;
---

<header class="site-header">
  <div class="container nav-shell">
    <a class="brand" href="/#hero" aria-label={`${navbar.brandName} home`}>
      <span class="brand-mark">{navbar.brandMark}</span>
      <span class="nav-name">{navbar.brandName}</span>
    </a>
    
    <nav class="site-nav" id="siteNav">
      {navbar.links.map(link => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>

    <div class="nav-controls">
      <a href={navbar.resume.href} download class="nav-cta">{navbar.resume.label}</a>
      <button class="theme-icon-btn" id="themeToggle" type="button" aria-label="Toggle color theme" aria-pressed="false" title="Toggle color theme">
        <Sun className="theme-btn-icon theme-btn-icon--light" aria-hidden="true" weight="bold" />
        <Moon className="theme-btn-icon theme-btn-icon--dark" aria-hidden="true" weight="bold" />
      </button>
      <button class="icon-button menu-toggle" id="menuToggle" type="button" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="siteNav">
        <List className="menu-icon menu-icon-open" aria-hidden="true" weight="bold" />
        <X className="menu-icon menu-icon-close" aria-hidden="true" weight="bold" />
        <span class="button-text">Menu</span>
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--bg) 96%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
  }

  .nav-shell {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.9rem 0;
    flex-wrap: wrap;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    font-weight: 500;
    flex-shrink: 1;
    min-width: 0;
  }

  .brand-mark {
    display: inline-grid;
    place-items: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 4px;
    background: var(--surface-strong);
    border: none;
    color: var(--text);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    font-weight: 500;
    flex-shrink: 0;
  }

  .nav-name {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 450;
    font-size: 1rem;
    letter-spacing: -0.02em;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .nav-controls {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-shrink: 0;
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.45rem 1rem;
    border-radius: 4px;
    border: 1px solid var(--border);
    font-family: 'JetBrains Mono', monospace;
    font-weight: 450;
    font-size: 0.85rem;
    background: transparent;
    color: var(--text);
    transition: all var(--transition-fast);
  }

  .nav-cta:hover {
    background: var(--surface);
    color: var(--accent);
    border-color: var(--accent);
  }

  .theme-icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 4px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .theme-icon-btn:hover {
    color: var(--accent);
    background: var(--surface);
    border-color: var(--accent);
  }

  .theme-btn-icon {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  .theme-btn-icon--dark { display: block; }
  .theme-btn-icon--light { display: none; }

  :global([data-theme='dark']) .theme-btn-icon--dark { display: none; }
  :global([data-theme='dark']) .theme-btn-icon--light { display: block; }

  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme='light'])) .theme-btn-icon--dark { display: none; }
    :global(:root:not([data-theme='light'])) .theme-btn-icon--light { display: block; }
  }

  .icon-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text);
    border-radius: 4px;
    padding: 0.45rem 0.8rem;
    font: inherit;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .icon-button:hover {
    border-color: var(--accent);
    background: var(--surface);
  }

  .menu-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 2.1rem;
    padding: 0;
  }

  .menu-icon {
    width: 1.1rem;
    height: 1.1rem;
    display: inline-block;
    flex: 0 0 auto;
  }

  .menu-icon-close { display: none; }

  .site-nav {
    display: none;
    width: 100%;
    padding: 0.75rem 0 0.5rem;
    flex-direction: column;
    gap: 0.5rem;
  }

  .site-nav a {
    padding: 0.5rem 0.75rem;
    border-radius: 4px;
    color: var(--text-muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    font-weight: 450;
    transition: all var(--transition-fast);
  }

  .site-nav a:hover {
    background: var(--surface);
    color: var(--accent);
  }

  .site-header.nav-open .site-nav { display: flex; }
  .site-header.nav-open .menu-icon-open { display: none; }
  .site-header.nav-open .menu-icon-close { display: inline-block; }

  @media (min-width: 700px) {
    .menu-toggle { display: none; }
    .site-nav {
      display: flex !important;
      width: auto;
      padding: 0;
      flex-direction: row;
      gap: 0.2rem;
      align-items: center;
      margin-left: auto;
    }
    .site-nav a {
      padding: 0.5rem 1rem;
      font-size: 0.9rem;
    }
  }

  @media (max-width: 699px) {
    .nav-shell {
      padding-left: 1rem;
      padding-right: 1rem;
      gap: 0.75rem;
    }
    .nav-name {
      white-space: normal;
      font-size: 0.9rem;
      max-width: 130px;
    }
    .brand {
      gap: 0.5rem;
    }
    .brand-mark {
      width: 1.8rem;
      height: 1.8rem;
      font-size: 0.75rem;
    }
    .nav-controls {
      gap: 0.6rem;
    }
    .nav-cta {
      display: none !important;
    }
    .theme-icon-btn {
      width: 2.75rem;
      height: 2.75rem;
    }
    .theme-btn-icon {
      width: 1.3rem;
      height: 1.3rem;
    }
    .menu-toggle {
      width: 2.75rem;
      height: 2.75rem;
    }
    .menu-icon {
      width: 1.4rem;
      height: 1.4rem;
    }
    .site-nav {
      order: 3;
    }
    .button-text {
      display: none;
    }
    .site-nav a {
      padding: 0.75rem 1rem;
      font-size: 1rem;
    }
  }
</style>