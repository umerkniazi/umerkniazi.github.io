---
import { Icon } from 'astro-icon/components';

interface Props {
  name: string;
  description: string;
  summary?: string;
  stack?: string[];
  outcome?: string[];
  features?: string[];
  demoUrl?: string | null;
  demoLabel?: string;
  sourceUrl?: string | null;
  headingLevel?: 'h2' | 'h3';
  variant?: 'detailed' | 'minimal';
}

const {
  name,
  description,
  summary,
  stack,
  outcome,
  features,
  demoUrl,
  demoLabel = 'Demo',
  sourceUrl,
  headingLevel = 'h3',
  variant = 'detailed',
} = Astro.props;

const Heading = headingLevel;
---

{
  variant === 'minimal' ? (
    <article class="flex flex-col">
      <Heading class="text-base font-semibold tracking-tight text-ink">{name}</Heading>
      <p class="mt-2 text-sm leading-relaxed text-body">{summary || description}</p>
    </article>
  ) : (
    <article class="project-card">
      <Heading class="project-card-heading">{name}</Heading>

      <p class="mt-3 text-sm leading-relaxed text-body">{description}</p>

      {stack && stack.length > 0 && (
        <p class="mt-4 text-xs text-faint">{stack.join(' · ')}</p>
      )}

      {outcome && outcome.length > 0 && (
        <p class="mt-3 flex flex-wrap gap-x-3 gap-y-1 text-xs text-accent">
          {outcome.map((stat, i) => (
            <span>
              {stat}{i < outcome.length - 1 ? <span class="text-border-strong"> · </span> : null}
            </span>
          ))}
        </p>
      )}

      {features && features.length > 0 && (
        <p class="mt-3 flex flex-wrap gap-x-3 gap-y-1 text-xs text-muted">
          {features.map((feature, i) => (
            <span>
              {feature}{i < features.length - 1 ? <span class="text-border-strong"> · </span> : null}
            </span>
          ))}
        </p>
      )}

      <div class="mt-auto pt-8 flex gap-5 text-sm">
        {demoUrl && (
          <a
            href={demoUrl}
            target="_blank"
            rel="noreferrer"
            class="flex items-center gap-1 rounded-sm text-accent underline-offset-4 hover-underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-surface"
          >
            <Icon name="tabler:external-link" class="h-3.5 w-3.5" aria-hidden="true" />
            {demoLabel}
          </a>
        )}
        {sourceUrl && (
          <a
            href={sourceUrl}
            target="_blank"
            rel="noreferrer"
            class="flex items-center gap-1 rounded-sm text-muted underline-offset-4 hover-text-accent hover-underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-surface"
          >
            <Icon name="tabler:brand-github" class="h-3.5 w-3.5" aria-hidden="true" />
            Source
          </a>
        )}
      </div>
    </article>
  )
}