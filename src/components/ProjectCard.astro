---
import { Icon } from 'astro-icon/components';

interface Props {
  name: string;
  description: string;
  summary?: string;
  stack?: string[];
  demoUrl?: string | null;
  sourceUrl?: string | null;
  headingLevel?: 'h2' | 'h3';
  variant?: 'detailed' | 'minimal';
}

const {
  name,
  description,
  summary,
  stack,
  demoUrl,
  sourceUrl,
  headingLevel = 'h3',
  variant = 'detailed',
} = Astro.props;

const Heading = headingLevel;
---

{
  variant === 'minimal' ? (
    <article class="flex flex-col">
      <Heading class="text-base font-semibold tracking-tight text-ink">{name}</Heading>
      <p class="mt-2 text-sm leading-relaxed text-body">{summary || description}</p>

      <div class="mt-4 flex gap-5 text-sm">
        {demoUrl && (
          <a
            href={demoUrl}
            target="_blank"
            rel="noreferrer"
            class="flex items-center gap-1 text-accent underline-offset-4 hover:underline"
          >
            <Icon name="tabler:external-link" class="h-3.5 w-3.5" aria-hidden="true" />
            Demo
          </a>
        )}
        {sourceUrl && (
          <a
            href={sourceUrl}
            target="_blank"
            rel="noreferrer"
            class="flex items-center gap-1 text-muted underline-offset-4 hover:text-accent hover:underline"
          >
            <Icon name="tabler:brand-github" class="h-3.5 w-3.5" aria-hidden="true" />
            Source
          </a>
        )}
      </div>
    </article>
  ) : (
    <article class="group flex min-h-[16rem] flex-col rounded-md border border-border bg-surface p-6 transition-colors duration-150 hover:border-border-strong hover:bg-surface-hover sm:p-8">
      <Heading class="text-base font-semibold text-body transition-colors duration-150 group-hover:text-ink">{name}</Heading>

      <p class="mt-3 text-sm leading-relaxed text-body">{description}</p>

      {stack && stack.length > 0 && (
        <p class="mt-4 text-xs text-faint">{stack.join(' · ')}</p>
      )}

      <div class="mt-auto pt-8 flex gap-5 text-sm">
        {demoUrl && (
          <a
            href={demoUrl}
            target="_blank"
            rel="noreferrer"
            class="flex items-center gap-1 text-accent underline-offset-4 hover:underline"
          >
            <Icon name="tabler:external-link" class="h-3.5 w-3.5" aria-hidden="true" />
            Demo
          </a>
        )}
        {sourceUrl && (
          <a
            href={sourceUrl}
            target="_blank"
            rel="noreferrer"
            class="flex items-center gap-1 text-muted underline-offset-4 hover:text-accent hover:underline"
          >
            <Icon name="tabler:brand-github" class="h-3.5 w-3.5" aria-hidden="true" />
            Source
          </a>
        )}
      </div>
    </article>
  )
}