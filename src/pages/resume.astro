---
import { Icon } from 'astro-icon/components';
import Base from '../layouts/Base.astro';
import { site } from '../data/site.js';
---

<Base title="Resume" description={`Resume for ${site.name}.`}>
  <h1 class="text-3xl font-bold tracking-tight text-ink">Resume</h1>
  <p class="mt-3 max-w-prose text-sm leading-relaxed text-body">
    The PDF below is the latest version of my resume and is available to view or download.
  </p>

  <div class="mt-6 flex flex-wrap gap-3">
    <a href={site.resumeUrl} download class="btn-primary">
      <Icon name="tabler:download" class="h-4 w-4" aria-hidden="true" />
      Download PDF
    </a>
    <a href={site.resumeUrl} target="_blank" rel="noreferrer" class="btn-secondary">
      <Icon name="tabler:external-link" class="h-4 w-4" aria-hidden="true" />
      Open in new tab
    </a>
  </div>

  <div class="mt-8 max-w-content overflow-hidden rounded-md border border-border bg-surface">
    <iframe
      src={`${site.resumeUrl}#toolbar=0&navpanes=0&view=FitH`}
      title={`${site.name} resume PDF`}
      class="h-[75vh] w-full"
      loading="lazy"
    >
      <p class="p-6 text-sm text-body">
        Your browser doesn't support inline PDFs.
        <a href={site.resumeUrl} class="text-accent hover:underline">Download the PDF</a> instead.
      </p>
    </iframe>
  </div>
</Base>