---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config';

const { error404 } = siteConfig;
const title = '404 | Page Not Found';
---

<Layout title={title} description="The page you requested could not be found.">
  <Header />
  <main id="main">
    <section class="section error-page">
      <div class="container error-page-shell">
        <div class="error-content card card-strong">
          <p class="error-eyebrow">{error404.eyebrow}</p>
          <h1 class="error-title">{error404.title}</h1>
          <p class="error-message">{error404.message}</p>

          <a class="error-link button" href={error404.cta.href}>
            {error404.cta.label}
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .error-page {
    min-height: 68vh;
    display: grid;
    align-items: center;
  }

  .error-page-shell {
    display: grid;
    place-items: start;
  }

  .error-content {
    max-width: 36rem;
    padding: var(--space-8);
    display: grid;
    gap: var(--space-4);
  }

  .error-eyebrow {
    color: var(--text-subtle);
    font-size: var(--text-xs);
    font-weight: 600;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .error-title {
    color: var(--text);
  }

  .error-message {
    color: var(--text-muted);
    line-height: var(--leading-normal);
  }

  .error-link {
    width: fit-content;
  }

  @media (max-width: 720px) {
    .error-content {
      padding: var(--space-6);
    }
  }
</style>