---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config';

const { error404 } = siteConfig;
const title = '404 | Page Not Found';
---

<Layout title={title} description="The page you requested could not be found.">
  <Header />
  <main id="main">
    <section class="section container error-page">
      <h1 class="error-title">404</h1>
      <div class="error-status">{error404.title}</div>
      <p class="error-message">{error404.message}</p>
      
      <a class="error-link" href={error404.cta.href}>
        &lt; {error404.cta.label}
      </a>
    </section>
  </main>
  <Footer />
  <script is:inline src="/script.js" defer></script>
</Layout>

<style>
  .error-page {
    padding-top: 6rem;
    display: flex;
    flex-direction: column;
    min-height: 50vh;
  }

  .error-title {
    font-size: 1.5rem;
    color: var(--text);
    margin-bottom: 0.2rem;
  }

  .error-status {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .error-message {
    color: var(--text-muted);
    max-width: 65ch;
    margin-bottom: 2rem;
  }

  .error-link {
    color: var(--text-muted);
    text-decoration: none;
    width: fit-content;
    transition: color 0.2s ease;
  }

  .error-link:hover {
    color: var(--accent);
  }
</style>