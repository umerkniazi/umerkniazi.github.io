---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Terminal from '../components/Terminal.astro';
import { siteConfig } from '../config';

const { error404 } = siteConfig;
const title = '404 | Page Not Found';
---

<Layout title={title} description="The page you requested could not be found.">
  <Header />
  <main id="main">
    <section class="section error-page" data-reveal>
      <div class="container narrow">
        <p class="eyebrow">{error404.eyebrow}</p>
        <h1>{error404.title}</h1>
        
        <Terminal 
          meta={error404.terminal.meta}
          prompt={error404.terminal.prompt}
          command={error404.terminal.command}
          output={error404.terminal.output}
        />

        <p class="error-copy">
          {error404.message}
        </p>
        
        <div class="error-actions">
          <a class="hero-cta" href={error404.cta.href}>{error404.cta.label}</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <script is:inline src="/script.js" defer></script>
</Layout>

<style>
  /* same as before */
  .section {
    padding: 6rem 0;
  }

  .error-page {
    min-height: calc(100vh - 14rem);
    display: grid;
    align-items: center;
    padding-top: 5rem;
  }

  .eyebrow {
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    color: var(--accent);
    font-size: 0.84rem;
    letter-spacing: 0.02em;
    margin: 0 0 0.6rem;
  }

  .error-page h1 {
    max-width: none;
    font-size: clamp(3rem, 8vw, 4.5rem);
    margin-bottom: 2rem;
  }

  .error-copy {
    margin: 2rem 0 2rem;
    max-width: 55ch;
    color: var(--text-muted);
    line-height: 1.75;
    font-size: 1.08rem;
  }

  .error-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 2.5rem;
    padding: 0.6rem 1.4rem;
    border: 1px solid var(--accent);
    border-radius: 2px;
    color: var(--bg) !important;
    font-weight: 400;
    font-size: 0.92rem;
    background: var(--accent);
    transition: all var(--transition-fast);
  }

  .hero-cta:hover {
    background: transparent;
    color: var(--accent) !important;
  }

  @media (max-width: 699px) {
    .section {
      padding: 4rem 0;
    }
  }
</style>