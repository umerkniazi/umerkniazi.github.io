---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config';

const { error404 } = siteConfig;
const title = '404 | Page Not Found';
---

<Layout title={title} description="The page you requested could not be found.">
  <Header />
  <main id="main">
    <section class="section container error-page">
      <h1 class="error-title">404</h1>
      <p class="error-status">{error404.title.toLowerCase()}</p>
      <p class="error-message">{error404.message}</p>
      
      <a class="error-link" href={error404.cta.href}>
        [{error404.cta.label.toLowerCase()}]
      </a>
    </section>
  </main>
  <Footer />
  <script is:inline src="/script.js" defer></script>
</Layout>

<style>
  .error-page {
    padding-top: 6rem;
    padding-bottom: 4rem;
    display: flex;
    flex-direction: column;
    min-height: 50vh;
  }

  .error-title {
    font-size: 1.8rem;
    font-weight: bold;
    color: var(--text);
    margin-bottom: 0.25rem;
    letter-spacing: -0.02em;
  }

  .error-status {
    color: var(--accent);
    margin-bottom: 1.5rem;
    font-size: 1rem;
  }

  .error-message {
    color: var(--text-muted);
    max-width: 65ch;
    margin-bottom: 2.5rem;
    line-height: 1.6;
  }

  .error-link {
    color: var(--text-muted);
    text-decoration: none;
    width: fit-content;
    transition: color 0.2s ease;
    outline: none;
    font-size: 1rem;
  }

  .error-link:hover,
  .error-link:focus-visible {
    color: var(--accent);
  }

  .error-link:focus-visible {
    text-decoration: underline;
    text-underline-offset: 4px;
  }
</style>