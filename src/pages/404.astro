---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config';

const { error404 } = siteConfig;
const title = '404 | Page Not Found';
---

<Layout title={title} description="The page you requested could not be found.">
  <Header />
  <main id="main">
    <section class="section container error-page">
      <div class="error-content">
        <p class="error-eyebrow">{error404.eyebrow}</p>
        <h1 class="error-title">{error404.title}</h1>
        <p class="error-message">{error404.message}</p>
        
        <a class="error-link" href={error404.cta.href}>
          {error404.cta.label}
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .error-page {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 60vh;
  }

  .error-eyebrow {
    color: var(--accent);
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .error-title {
    font-size: 2.5rem;
    color: var(--text);
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .error-message {
    color: var(--text-muted);
    max-width: 50ch;
    margin-bottom: 2.5rem;
    font-size: 1.05rem;
  }

  .error-link {
    display: inline-block;
    color: var(--text);
    font-weight: 500;
  }

  .error-link:hover {
    color: var(--accent);
  }
</style>