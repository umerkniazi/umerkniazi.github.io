---
import { Icon } from 'astro-icon/components';
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { site } from '../data/site.js';
import { projects } from '../data/projects.js';

const featured = projects.filter((p) => p.featured);
---

<Base title={site.name}>
  <section class="max-w-prose">
    <h1 class="text-4xl font-bold tracking-tight text-ink sm:text-5xl">{site.name}</h1>
    <p class="mt-2 text-lg text-muted">{site.role}</p>
    <p class="mt-6 text-base leading-relaxed text-body">{site.tagline}</p>

    <dl class="mt-8 flex flex-col gap-2 text-sm text-muted">
      <div>
        <dt class="sr-only">Current focus</dt>
        <dd><span class="text-faint">focus</span> · {site.currentFocus}</dd>
      </div>
      <div>
        <dt class="sr-only">Availability</dt>
        <dd>
          <span class="text-faint">status</span> · {
            site.available ? (
              <span>{site.statusText}<span class="caret" aria-hidden="true" /></span>
            ) : (
              <span>Not currently available</span>
            )
          }
        </dd>
      </div>
    </dl>

    <div class="mt-8 flex flex-wrap gap-3">
      <a href={site.github} target="_blank" rel="noreferrer" class="btn-primary">
        <Icon name="tabler:brand-github" class="h-4 w-4" aria-hidden="true" />
        GitHub
      </a>
      <a href="/resume" class="btn-secondary">
        <Icon name="tabler:file-text" class="h-4 w-4" aria-hidden="true" />
        Resume
      </a>
    </div>

    <p class="mt-6 text-sm">
      <a href="/about" class="text-accent underline-offset-4 hover:underline">More about me and how I work →</a>
    </p>
  </section>

  <section class="mt-16 sm:mt-20" aria-labelledby="projects-heading">
    <div class="flex items-baseline justify-between">
      <h2 id="projects-heading" class="text-xl font-semibold tracking-tight text-ink">Featured Projects</h2>
      <a href="/projects" class="text-sm text-muted hover:text-accent hover:underline">All projects →</a>
    </div>

    <div class="mt-10 grid grid-cols-1 gap-12 sm:grid-cols-2 sm:gap-10">
      {featured.map((project) => <ProjectCard {...project} variant="minimal" />)}
    </div>
  </section>
</Base>